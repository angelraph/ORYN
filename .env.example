# Celo mainnet RPC
CELO_RPC_URL=https://forno.celo.org

# ORYN agent's own automation wallet (funded with a small amount of CELO for gas).
# This wallet can only call distribute() on vaults it's authorized on — it can
# never withdraw or redirect funds. See contracts/OrynVault.sol.
AGENT_PRIVATE_KEY=

# cUSD on Celo mainnet
CUSD_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a

# Set after `npm run deploy:mainnet` (both printed by the deploy script;
# DEPLOY_BLOCK can also be found exactly via scripts/findDeployBlock.ts)
VAULT_FACTORY_ADDRESS=
VAULT_FACTORY_DEPLOY_BLOCK=

# From Celo Builders registration — DO NOT change, must match exactly.
# Every ORYN transaction must append this via toDataSuffix().
ATTRIBUTION_TAG=celo_2a23542d598e

# x402 (Track 2) — Celo facilitator does not support cUSD, use USDC.
X402_FACILITATOR_URL=https://api.x402.celo.org
USDC_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
X402_SELLER_PAYOUT_ADDRESS=
# Get one at https://x402.celo.org -> connect wallet -> "Create API key".
# Required for /settle to succeed; without it you'll see 401 Missing X-API-Key.
X402_API_KEY=

# Celo Builders platform credential (from /auth/google/claim) — keep private.
CELO_BUILDERS_API_KEY=
