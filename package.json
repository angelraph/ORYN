{
  "name": "oryn",
  "version": "0.1.0",
  "private": true,
  "description": "ORYN — autonomous onchain treasury agent for Celo. Every incoming payment is split, saved, and paid out automatically, onchain.",
  "type": "module",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network celo",
    "agent": "tsx agent/src/index.ts",
    "x402:serve": "tsx x402-service/server.ts"
  },
  "dependencies": {
    "@celo/attribution-tags": "^0.3.0",
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "@x402/express": "^2.18.0",
    "@x402/fetch": "^2.18.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "viem": "^2.55.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "hardhat": "^3.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
